{
    "i18n": true,
    "type": "tabs",
    "tabsStyle": {
        "width": "calc(100% - 100px)"
    },
    "items": {
        "_tab_Start": {
            "type": "panel",
            "label": "Main Settings",
            "items": {
                "header_Start": {
                    "type": "header",
                    "text": "Welcome to X-Sense Adapter",
                    "size": 2
                },
                "_textStart": {
                    "type": "staticText",
                    "text": "Connects directly to the X-Sense Cloud (AWS Cognito + IoT) without Python. Optionally receives real-time updates via MQTT when a SBS50 Bridge is present (requires X-Sense App >= 1.34).",
                    "xs": 12,
                    "sm": 12,
                    "md": 6,
                    "lg": 4,
                    "xl": 4,
                    "style": {
                        "fontSize": 16,
                        "marginTop": 0
                    }
                },
                "_documentationLinkGerman": {
                    "type": "staticLink",
                    "label": "🇩🇪 Deutsche Dokumentation",
                    "button": true,
                    "href": "https://github.com/arteck/ioBroker.xsense/blob/main/README_de.md",
                    "xs": 12,
                    "sm": 12,
                    "md": 6,
                    "lg": 4,
                    "xl": 4,
                    "style": {
                        "fontSize": 16,
                        "marginTop": 0
                    }
                },
                "_documentationLinkEnglish": {
                    "type": "staticLink",
                    "label": "🇬🇧 English Documentation",
                    "button": true,
                    "href": "https://github.com/arteck/ioBroker.xsense/blob/main/README.md",
                    "xs": 12,
                    "sm": 12,
                    "md": 6,
                    "lg": 4,
                    "xl": 4,
                    "style": {
                        "fontSize": 16,
                        "marginTop": 0
                    }
                },

                "header2": {
                    "type": "header",
                    "text": " ",
                    "size": 2
                },

                "spacer01": {
                  "type": "staticText",
                  "text": "",
                  "xs": 12,
                  "sm": 12,
                  "md": 6,
                  "lg": 4,
                  "xl": 4,
                  "newLine": true
                },
                "userEmail": {
                    "newLine": true,
                    "type": "text",
                    "label": "User email",
                    "help": "login email for X-Sense Cloud",
                    "hidden": "data.mqttDoNotVerifyUserPw",
                    "xs": 12,
                    "sm": 12,
                    "md": 6,
                    "lg": 4,
                    "xl": 4
                },
                "userPassword": {
                    "type": "password",
                    "label": "Password",
                    "help": "Password for X-Sense Cloud",
                    "hidden": "data.mqttDoNotVerifyUserPw",
                    "repeat": true,
                    "xs": 12,
                    "sm": 12,
                    "md": 6,
                    "lg": 4,
                    "xl": 4
                },
                "polltime": {
                    "newLine": true,
                    "type": "number",
                    "label": "Polling interval",
                    "help": "Without MQTT: full device state poll. With MQTT: only structural sync (loadAll). Minimum 60s.",
                    "min": 60,
                    "max": 3600,
                    "step": 1,
                    "default": 300,
                    "xs": 12,
                    "sm": 12,
                    "md": 6,
                    "lg": 4,
                    "xl": 4
                },
                "spacer02": {
                  "type": "staticText",
                  "text": "",
                  "xs": 12,
                  "sm": 12,
                  "md": 6,
                  "lg": 4,
                  "xl": 4,
                  "newLine": true
                },
                "useMqttServer": {
                  "type": "checkbox",
                  "label": "Use MQTT. You need XSense APP Version >= 1.34",
                  "newLine": true,
                  "xs": 12,
                  "sm": 12,
                  "md": 6,
                  "lg": 4,
                  "xl": 4
                },
                "spacer03": {
                  "type": "staticText",
                  "text": "MQTT Server Configuration",
                  "xs": 12,
                  "sm": 12,
                  "md": 6,
                  "lg": 4,
                  "xl": 4,
                  "newLine": true,
                  "hidden": "data.useMqttServer == false"
                },
                "connectionType": {
                  "label": "Select connection",
                  "xs": 12,
                  "sm": 12,
                  "md": 6,
                  "lg": 4,
                  "xl": 4,
                  "type": "select",
                  "options": [
                    {
                      "label": "External MQTT-Server",
                      "value": "exmqtt"
                    },
                    {
                      "label": "Internal MQTT-Server",
                      "value": "intmqtt"
                    }
                  ],
                  "newLine": true,
                  "hidden": "data.useMqttServer == false"
                },
                "baseTopic": {
                  "type": "text",
                  "label": "Base MQTT topic",
                  "xs": 12,
                  "sm": 12,
                  "md": 6,
                  "lg": 4,
                  "xl": 4,
                  "default": "homeassistant/binary_sensor/#",
                  "disabled": "true",
                  "hidden": "data.connectionType == 'intmqtt' || data.useMqttServer == false"
                },
                "spacer04": {
                  "type": "staticText",
                  "text": "Configure your connection",
                  "xs": 12,
                  "sm": 12,
                  "md": 6,
                  "lg": 4,
                  "xl": 4,
                  "newLine": true,
                  "hidden": "data.useMqttServer == false"
                },
                "externalMqttServerIP": {
                  "type": "text",
                  "label": "External MQTT-Server IP-Address",
                  "newLine": true,
                  "xs": 12,
                  "sm": 12,
                  "md": 6,
                  "lg": 4,
                  "xl": 4,
                  "hidden": "data.connectionType == 'intmqtt' || data.useMqttServer == false"
                },
                "externalMqttServerPort": {
                  "type": "number",
                  "label": "External MQTT-Server Port",
                  "newLine": false,
                  "xs": 12,
                  "sm": 12,
                  "md": 6,
                  "lg": 4,
                  "xl": 4,
                  "hidden": "data.connectionType == 'intmqtt' || data.useMqttServer == false"
                },
                "externalMqttServerCredentials": {
                  "type": "checkbox",
                  "label": "Use MQTT Credentials",
                  "newLine": true,
                  "xs": 12,
                  "sm": 12,
                  "md": 6,
                  "lg": 4,
                  "xl": 4,
                  "hidden": "data.connectionType == 'intmqtt' || data.useMqttServer == false"
                },
                "externalMqttServerUsername": {
                  "type": "text",
                  "label": "MQTT Username",
                  "newLine": true,
                  "xs": 12,
                  "sm": 12,
                  "md": 6,
                  "lg": 4,
                  "xl": 4,
                  "hidden": "data.externalMqttServerCredentials == false || data.connectionType == 'intmqtt' || data.useMqttServer == false"
                },
                "externalMqttServerPassword": {
                  "type": "password",
                  "label": "MQTT Password",
                  "newLine": false,
                  "xs": 12,
                  "sm": 12,
                  "md": 6,
                  "lg": 4,
                  "xl": 4,
                  "visible": true,
                  "hidden": "data.externalMqttServerCredentials == false || data.connectionType == 'intmqtt' || data.useMqttServer == false"
                },
                "mqttServerIPBind": {
                  "type": "ip",
                  "label": "MQTT-Server IP-Address bind",
                  "listenOnAllPorts": true,
                  "xs": 12,
                  "sm": 12,
                  "md": 6,
                  "lg": 4,
                  "xl": 4,
                  "newLine": true,
                  "hidden": "data.connectionType == 'exmqtt' || data.useMqttServer == false"
                },
                "mqttServerPort": {
                  "type": "number",
                  "label": "MQTT-Server Port",
                  "xs": 12,
                  "sm": 12,
                  "md": 6,
                  "lg": 4,
                  "xl": 4,
                  "newLine": false,
                  "hidden": "data.connectionType == 'exmqtt' || data.useMqttServer == false"
                },
              "mqttmessages": {
                  "type": "checkbox",
                  "label": "MQTT Messages log",
                  "newLine": true,
                  "xs": 12,
                  "sm": 12,
                  "md": 6,
                  "lg": 4,
                  "xl": 4,
                   "hidden": "data.useMqttServer == false"
                }
            }
        }
    }
}
